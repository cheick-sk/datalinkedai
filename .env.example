# ═══════════════════════════════════════════════════════
#  DataLinkedAI v3.0 — Stack 100% GRATUITE
# ═══════════════════════════════════════════════════════

# ── IA — GROQ (gratuit, pas de CB) ──────────────────
# console.groq.com → Sign up → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Securite ────────────────────────────────────────
API_KEY=datalinked-2025-secret

# ── Base de donnees — Supabase (gratuit) ────────────
# supabase.com → New project → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── Email — Gmail SMTP (gratuit) ────────────────────
# myaccount.google.com → Securite → Mots de passe applications
GMAIL_USER=kaba.sekouna@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ── Copilot ─────────────────────────────────────────
COPILOT_EMAIL=kaba.sekouna@gmail.com
COPILOT_HOUR=8
AUTO_APPLY=false
AUTO_APPLY_MIN_SCORE=85
FOLLOWUP_DAYS=5

# APIFY_TOKEN= (optionnel et payant — sans ca : offres mock)

# ── Notifications mobiles (Pushover) ──────────────────────────────
# Inscription gratuite sur https://pushover.net
# Télécharge l'app Pushover sur ton mobile
PUSHOVER_TOKEN=your_app_token_here
PUSHOVER_USER=your_user_key_here

# ── URL du dashboard (pour les liens dans les emails et notifs) ────
DASHBOARD_URL=https://datalinkedai.onrender.com/dashboard

# ── Enrichissement email recruteur (Hunter.io) ─────────────────────
# Inscription gratuite : https://hunter.io — 100 recherches/mois
HUNTER_API_KEY=your_hunter_api_key_here

# ── Gmail Parsing — détection automatique des réponses ────────────
# Même compte Gmail que pour l'envoi (GMAIL_USER + GMAIL_APP_PASS)
# Activer/désactiver le parsing automatique
GMAIL_PARSE_ENABLED=true
