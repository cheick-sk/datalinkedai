# ═══════════════════════════════════════════════════════════════
#  DataLinkedAI v12 — Configuration GRATUITE complète
#  Copie ce fichier en .env et remplis tes valeurs
# ═══════════════════════════════════════════════════════════════

# ── 🔑 Sécurité (OBLIGATOIRE) ────────────────────────────────
API_KEY=datalinked-2025-secret
DASHBOARD_URL=https://TON-APP.onrender.com/dashboard

# ── 🤖 IA — GROQ (GRATUIT, sans CB) ─────────────────────────
# → console.groq.com → Sign Up → API Keys → Create Key
GROQ_API_KEY=gsk_xxxx

# ── 🗄️ Base de données — Supabase (GRATUIT) ──────────────────
# Sans DATABASE_URL = SQLite local (ok pour débuter)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── 📧 Email — Gmail SMTP (GRATUIT) ──────────────────────────
# myaccount.google.com → Sécurité → Mots de passe d'application
GMAIL_USER=ton.email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
COPILOT_EMAIL=ton.email@gmail.com

# ── 🔔 Notifications WhatsApp — Twilio Sandbox (GRATUIT) ─────
# twilio.com → Console → Account SID + Auth Token
# Messaging → Try it out → WhatsApp → rejoindre le sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
NOTIF_WHATSAPP=+33612345678
NOTIF_CHANNELS=email,whatsapp

# ── 💼 LinkedIn (optionnel) ──────────────────────────────────
LINKEDIN_ACCESS_TOKEN=AQV...
LINKEDIN_PERSON_ID=ABC123xyz
LINKEDIN_AUTO_POST=false

# ── 🤖 Copilot ───────────────────────────────────────────────
COPILOT_HOUR=8
AUTO_APPLY=false
FOLLOWUP_DAYS=5

# ═══ STACK MINIMALE GRATUITE ═══════════════════════════════════
#  Obligatoire : GROQ_API_KEY + API_KEY + GMAIL_USER + GMAIL_APP_PASS + DASHBOARD_URL
#  Tout le reste est optionnel.
# ═══════════════════════════════════════════════════════════════
